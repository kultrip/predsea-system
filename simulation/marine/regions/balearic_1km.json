{
  "schema_version": "predsea.marine_region.v1",
  "region_id": "balearic_1km",
  "label": "Balearic coastal forecast tile",
  "bbox": {
    "longitude_min": 0.5,
    "longitude_max": 5.5,
    "latitude_min": 37.5,
    "latitude_max": 41.5
  },
  "horizontal_resolution_m": 1000,
  "output_interval_hours": 1,
  "models": {
    "swan": {
      "directions": 36,
      "frequencies": 32,
      "required_variables": [
        "significant_wave_height"
      ],
      "physical_ranges": {
        "significant_wave_height": [0.0, 20.0],
        "peak_wave_period": [0.0, 40.0],
        "mean_wave_direction": [0.0, 360.0]
      }
    },
    "croco": {
      "vertical_levels": 30,
      "required_variables": [
        "eastward_current",
        "northward_current",
        "sea_surface_temperature",
        "sea_surface_salinity",
        "sea_surface_height"
      ],
      "physical_ranges": {
        "eastward_current": [-5.0, 5.0],
        "northward_current": [-5.0, 5.0],
        "sea_surface_temperature": [-2.5, 40.0],
        "sea_surface_salinity": [0.0, 45.0],
        "sea_surface_height": [-5.0, 5.0]
      }
    }
  },
  "forcing": {
    "atmosphere": "predsea_wrf",
    "ocean_initial_and_boundary": "cmems",
    "wave_open_boundary": "cmems"
  }
}
